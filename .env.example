# Copia este archivo a ".env" y rellena tus claves de Supabase.
# El archivo .env NO se sube a GitHub (está en .gitignore).

# Las encuentras en Supabase: Project Settings → API
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_KEY=tu-service-role-key-aqui

# Código postal usado para consultar precios de Mercadona (su API es por zona).
# Pon el tuyo. Por defecto usamos uno de Madrid.
MERCADONA_POSTAL_CODE=28001
